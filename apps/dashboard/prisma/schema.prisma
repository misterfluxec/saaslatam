generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model radacct {
  radacctid           BigInt    @id @default(autoincrement())
  acctsessionid       String    @db.VarChar(64)
  username            String    @db.VarChar(64)
  groupname           String?   @db.VarChar(64)
  realm               String?   @db.VarChar(64)
  nasipaddress        String    @db.Inet
  nasportid           String?   @db.VarChar(15)
  nasporttype         String?   @db.VarChar(32)
  acctstarttime       DateTime? @db.Timestamptz(6)
  acctstoptime        DateTime? @db.Timestamptz(6)
  acctsessiontime     BigInt?   @default(0)
  acctauthentic       String?   @db.VarChar(32)
  connectinfo_start   String?   @db.VarChar(50)
  connectinfo_stop    String?   @db.VarChar(50)
  acctinputoctets     BigInt?   @default(0)
  acctoutputoctets    BigInt?   @default(0)
  calledstationid     String?   @db.VarChar(50)
  callingstationid    String?   @db.VarChar(50)
  acctterminatecause  String?   @db.VarChar(32)
  servicetype         String?   @db.VarChar(32)
  framedprotocol      String?   @db.VarChar(32)
  framedipaddress     String?   @db.Inet
  framedipv6address   String?   @db.Inet
  framedipv6prefix    String?   @db.Inet
  framedinterfaceid   String?   @db.VarChar(32)
  delegatedipv6prefix String?   @db.Inet
}

model radcheck {
  id        Int    @id @default(autoincrement())
  username  String @db.VarChar(64)
  attribute String @db.VarChar(64)
  op        String @db.VarChar(2)
  value     String @db.VarChar(253)
}

model radclients {
  id            Int     @id @default(autoincrement())
  client_id     String  @unique @db.VarChar(64)
  client_secret String  @db.VarChar(64)
  shortname     String? @db.VarChar(64)
  nastype       String? @default("other") @db.VarChar(64)
  ports         Int?
  secret        String  @db.VarChar(60)
  server        String? @db.VarChar(64)
  description   String?
}

model radreply {
  id        Int    @id @default(autoincrement())
  username  String @db.VarChar(64)
  attribute String @db.VarChar(64)
  op        String @db.VarChar(2)
  value     String @db.VarChar(253)
}

model radusergroup {
  id        Int    @id @default(autoincrement())
  username  String @db.VarChar(64)
  groupname String @db.VarChar(64)
  priority  Int?   @default(0)
}
