generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ✅ TENANT: Raíz del multi-tenancy
model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique // Para URLs: app.saaslatam.com/[slug]
  plan        String   @default("free") // free, pro, enterprise
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relaciones
  users       User[]
  branches    Branch[]
  campaigns   Campaign[]
  portals     Portal[]
  
  @@index([slug])
}

// ✅ USER: Roles con aislamiento por tenant
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String   // Hash con bcrypt
  role      Role     @default(CLIENT)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  @@unique([email, tenantId]) // Mismo email puede existir en tenants distintos
  @@index([tenantId])
}

enum Role {
  SUPERADMIN  // Plataforma global
  TENANT      // Dueño del negocio
  MARKETING   // Gestor de campañas
  CLIENT      // Usuario final del portal cautivo
}

// ✅ BRANCH: Sucursales multi-tenant
model Branch {
  id          String   @id @default(cuid())
  name        String
  location    String?
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  
  portals     Portal[]
  campaigns   Campaign[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([tenantId])
}

// ✅ CAMPAIGN: Motor de marketing con IA
model Campaign {
  id          String   @id @default(cuid())
  name        String
  branchId    String
  branch      Branch   @relation(fields: [branchId], references: [id])
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  
  // Contenido generado o sugerido por IA
  adCopy      String   // Texto del anuncio
  imageUrl    String?  // Imagen generada por IA
  targetAudience Json? // Criterios de segmentación
  
  // Métricas
  impressions Int      @default(0)
  clicks      Int      @default(0)
  conversions Int      @default(0)
  
  isActive    Boolean  @default(true)
  startDate   DateTime?
  endDate     DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([branchId, isActive])
}

// ✅ PORTAL: Configuración de portal cautivo por sucursal
model Portal {
  id            String   @id @default(cuid())
  name          String
  branchId      String
  branch        Branch   @relation(fields: [branchId], references: [id])
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  
  // Configuración de branding (IA puede sugerir valores)
  logoUrl       String?
  primaryColor  String   @default("#3b82f6")
  welcomeMsg    String?
  
  // Configuración técnica
  ssid          String
  radiusSecret  String   // Para FreeRADIUS
  sessionTimeout Int     @default(3600)
  
  analytics     Analytics[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([branchId])
}

// ✅ ANALYTICS: Datos para el dashboard
model Analytics {
  id        String   @id @default(cuid())
  portalId  String
  portal    Portal   @relation(fields: [portalId], references: [id])
  
  metric    String   // "users", "sessions", "bandwidth"
  value     Float
  timestamp DateTime @default(now())
  
  @@index([portalId, timestamp])
}
